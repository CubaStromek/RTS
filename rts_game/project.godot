; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Medieval RTS"
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.6")

[autoload]

GameManager="*res://scripts/managers/GameManager.gd"
UnitManager="*res://scripts/managers/UnitManager.gd"
SelectionSystem="*res://scripts/systems/SelectionSystem.gd"
CommandSystem="*res://scripts/systems/CommandSystem.gd"
ResourceSystem="*res://scripts/systems/ResourceSystem.gd"
SoundSystem="*res://scripts/systems/SoundSystem.gd"
BuildSystem="*res://scripts/systems/BuildSystem.gd"
NotificationSystem="*res://scripts/systems/NotificationSystem.gd"
TechSystem="*res://scripts/systems/TechSystem.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

